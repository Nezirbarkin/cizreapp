# Uncomment this line to define a global platform for this project
platform :ios, '15.0'

# CocoaPods configuration for Flutter
flutter_application_path = File.join(File.dirname(__FILE__), '.symlinks', '..')
load File.join(flutter_application_path, 'ios', 'Flutter', 'Podfile')

# Workspace configuration
workspace 'Runner.xcworkspace'

# Target configuration
target 'Runner' do
  use_frameworks!
  use_modular_headers!

  # Flutter pod installation
  flutter_install_all_ios_pods File.dirname(File.realpath(__FILE__))
end

# Post-install configuration
post_install do |installer|
  installer.pods_project.targets.each do |target|
    target.build_configurations.each do |config|
      config.build_settings['IPHONEOS_DEPLOYMENT_TARGET'] = '15.0'
      config.build_settings['GCC_PREPROCESSOR_DEFINITIONS'] ||= [
        '$(inherited)',
        'PERMISSION_CAMERA=1',
        'PERMISSION_PHOTOS=1',
        'PERMISSION_MICROPHONE=1',
        'PERMISSION_LOCATION=1',
      ]
    end
  end
end
